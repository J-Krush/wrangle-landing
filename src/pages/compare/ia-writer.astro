---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";

const version = import.meta.env.APP_VERSION;
const downloadUrl = `https://dl.wrangleapp.dev/Wrangle-${version}.dmg`;
---

<Layout
  title="wrangle vs iA Writer — markdown editor for developer workflows"
  description="iA Writer is a beautiful writing app. wrangle is a markdown editor built for developers working with AI agents — with embedded terminals, token counting, and first-class CLAUDE.md support."
  canonical="https://wrangleapp.dev/compare/ia-writer"
>
  <!-- Header -->
  <header class="flex items-center justify-between px-5 lg:px-[200px] py-4">
    <a href="/" class="flex items-center gap-2.5">
      <img
        src="/images/wrangle-logo-13.png"
        alt="wrangle logo"
        class="w-8 h-8 rounded"
      />
      <span class="text-base font-bold">wrangle</span>
    </a>
    <a
      href="/buy"
      class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-6 py-2.5 text-sm font-medium text-dark hover:brightness-110 transition-all"
    >
      buy — $24
    </a>
  </header>

  <!-- Hero -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-12 lg:pb-[80px] gap-8">
    <h1 class="text-[28px] sm:text-[36px] lg:text-[48px] font-bold text-center leading-[1.15] max-w-[1040px]">
      wrangle vs iA Writer
    </h1>
    <p class="text-secondary text-base lg:text-lg text-center leading-relaxed max-w-[800px]">
      iA Writer is one of the most beautiful writing apps ever made. but it was built for prose, not for developers configuring AI agents. different users, different needs.
    </p>
  </section>

  <!-- The Difference -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// writing app vs developer tool</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        iA Writer nails focused writing. the typography is perfect. focus mode dims everything except your current sentence. content blocks let you compose from multiple files. it's a joy for writing articles, books, and documentation.
      </p>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        but open a CLAUDE.md file with XML blocks in iA Writer and it has no idea what to do with it. try to count tokens — it can't. want to run an agent session? you'll need a separate terminal. iA Writer is a writing tool. wrangle is a developer tool.
      </p>
    </div>
  </section>

  <!-- Comparison -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// where wrangle wins</h2>
      <div class="h-2"></div>
      <div class="flex flex-col gap-5">
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">embedded terminals</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">run AI agent sessions in tabbed terminals inside the app. iA Writer is a pure writing tool with no terminal.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">agent notifications</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">native macOS notifications when agents need input or finish. you can work on other things and get pulled back at the right moment.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">token counting</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">always visible in the status bar. iA Writer counts words and reading time — great for articles, useless for prompts.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">xml-in-markdown</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">&lt;tools&gt;, &lt;instructions&gt;, &lt;system&gt; blocks get proper highlighting and collapsing. iA Writer doesn't recognize these patterns.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">AI file awareness</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">CLAUDE.md, SKILL.md, AGENTS.md files get distinct treatment. your file tree tells you what each file is at a glance.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">fuzzy finder</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">Cmd+P to jump to any file across all bookmarked projects. developer-grade file navigation.</span>
        </div>
        <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">session context</span>
          <span class="text-tertiary text-base hidden sm:inline">—</span>
          <span class="text-secondary text-base">every terminal shows linked config files, active skills, and MCP servers for the running agent.</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Where iA Writer Wins -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// where iA Writer wins</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        iA Writer is possibly the most refined markdown writing experience on any platform. the typography is genuinely beautiful. focus mode, syntax highlighting by parts of speech, content blocks — it's designed to make you a better writer.
      </p>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        it's also native on macOS, iOS, and Android. the iCloud sync is seamless. if you're writing blog posts, documentation, or a book, iA Writer is outstanding.
      </p>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        wrangle is not trying to be a better iA Writer. it's not trying to help you write prose. it's a workspace for developers who need to edit AI config files and manage agent sessions. use iA Writer for writing. use wrangle for AI development.
      </p>
    </div>
  </section>

  <!-- Who Should Switch -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// you might want wrangle if</h2>
      <div class="flex flex-col gap-4">
        <div class="flex items-start gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-secondary text-base">you've tried using iA Writer for CLAUDE.md files and it doesn't understand what they are</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-secondary text-base">you need to run AI agents and edit their configs in the same app</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-secondary text-base">you care about token counts, not word counts</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-secondary text-base">your markdown files have XML blocks that need proper handling, not HTML rendering</span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-secondary text-base">you want a developer-focused markdown tool, not a writing-focused one</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Comparison Table -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// quick comparison</h2>
      <div class="overflow-x-auto">
        <table class="w-full text-sm border-collapse">
          <thead>
            <tr class="border-b border-border">
              <th class="text-left py-3 pr-4 text-tertiary font-medium"></th>
              <th class="text-left py-3 px-4 text-teal-dark font-semibold">wrangle</th>
              <th class="text-left py-3 px-4 font-semibold">iA Writer</th>
            </tr>
          </thead>
          <tbody class="text-secondary">
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">focus</td>
              <td class="py-3 px-4">AI development workspace</td>
              <td class="py-3 px-4">focused writing</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">embedded terminals</td>
              <td class="py-3 px-4">yes, tabbed</td>
              <td class="py-3 px-4">no</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">agent notifications</td>
              <td class="py-3 px-4">native macOS alerts</td>
              <td class="py-3 px-4">no</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">token counting</td>
              <td class="py-3 px-4">built-in, always visible</td>
              <td class="py-3 px-4">word count only</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">XML in markdown</td>
              <td class="py-3 px-4">highlighted + collapsible</td>
              <td class="py-3 px-4">not recognized</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">focus mode</td>
              <td class="py-3 px-4">no</td>
              <td class="py-3 px-4">yes, excellent</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">typography</td>
              <td class="py-3 px-4">developer-focused (monospace)</td>
              <td class="py-3 px-4">beautiful, custom typeface</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">runtime</td>
              <td class="py-3 px-4">native macOS (Swift)</td>
              <td class="py-3 px-4">native (Swift)</td>
            </tr>
            <tr class="border-b border-border-subtle">
              <td class="py-3 pr-4 text-primary">platforms</td>
              <td class="py-3 px-4">macOS only</td>
              <td class="py-3 px-4">macOS, iOS, Android</td>
            </tr>
            <tr>
              <td class="py-3 pr-4 text-primary">price</td>
              <td class="py-3 px-4">$24 one-time</td>
              <td class="py-3 px-4">$50 one-time</td>
            </tr>
          </tbody>
        </table>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-6">
    <h2 class="text-[32px] lg:text-[40px] font-bold">wrangle</h2>
    <p class="text-secondary text-base text-center max-w-[500px]">
      the markdown editor for AI developers, not writers. embedded terminals, token counting, agent notifications. $24, one-time.
    </p>
    <div class="flex flex-col items-center gap-3">
      <a
        href="/buy"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-semibold text-dark hover:brightness-110 transition-all"
      >
        buy — $24
      </a>
      <a
        href={downloadUrl}
        class="text-secondary text-sm hover:text-primary transition-colors"
      >
        try free
      </a>
    </div>
    <span class="text-tertiary text-[13px]">macOS 15+ · apple silicon · one-time purchase</span>
  </section>

  <!-- Footer -->
  <footer class="flex items-center justify-between px-5 lg:px-[200px] py-5 border-t border-border-subtle">
    <div class="flex gap-3 text-tertiary text-xs">
      <span>© 2026 wrangle</span>
      <span>·</span>
      <a href="https://jkrush.dev" target="_blank" class="hover:text-secondary transition-colors">built by J-Krush</a>
    </div>
    <div class="flex gap-3 text-tertiary text-xs">
      <a href="mailto:support@wrangleapp.dev" class="hover:text-secondary transition-colors">support</a>
      <span>·</span>
      <a href="https://github.com/J-Krush/wrangle-feedback" class="hover:text-secondary transition-colors">github</a>
      <span>·</span>
      <a href="/terms" class="hover:text-secondary transition-colors">terms</a>
      <span>·</span>
      <a href="/refund" class="hover:text-secondary transition-colors">refund</a>
    </div>
  </footer>
</Layout>
