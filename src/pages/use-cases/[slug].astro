---
import Layout from "../../layouts/Layout.astro";
import "../../styles/global.css";
import useCases from "../../data/use-cases.json";

export function getStaticPaths() {
  return useCases.map((uc) => ({
    params: { slug: uc.slug },
    props: { useCase: uc },
  }));
}

const { useCase } = Astro.props;
const version = import.meta.env.APP_VERSION;
const downloadUrl = `https://dl.wrangleapp.dev/Wrangle-${version}.dmg`;
const canonical = `https://wrangleapp.dev/use-cases/${useCase.slug}`;

// Split body into paragraphs
const paragraphs = useCase.body.split("\n\n").filter((p: string) => p.trim());
---

<Layout title={useCase.title} description={useCase.metaDescription} canonical={canonical}>
  <!-- Header -->
  <header class="flex items-center justify-between px-5 lg:px-[200px] py-4">
    <a href="/" class="flex items-center gap-2.5">
      <img
        src="/images/wrangle-logo-13.png"
        alt="wrangle logo"
        class="w-8 h-8 rounded"
      />
      <span class="text-base font-bold">wrangle</span>
    </a>
    <a
      href={downloadUrl}
      class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-6 py-2.5 text-sm font-medium text-dark hover:brightness-110 transition-all"
    >
      try free
    </a>
  </header>

  <!-- Hero -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-12 lg:pb-[80px] gap-8">
    <h1 class="text-[28px] sm:text-[36px] lg:text-[44px] font-bold text-center leading-[1.15] max-w-[900px]">
      {useCase.h1}
    </h1>
    <p class="text-secondary text-base lg:text-lg text-center leading-relaxed max-w-[700px]">
      {useCase.intro}
    </p>
    <div class="flex flex-col items-center gap-3">
      <a
        href="/buy"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-semibold text-dark hover:brightness-110 transition-all"
      >
        buy — $24
      </a>
      <a
        href={downloadUrl}
        class="text-secondary text-sm hover:text-primary transition-colors"
      >
        try free
      </a>
    </div>
  </section>

  <!-- Screenshot -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pb-16 lg:pb-[100px]">
    <img
      src="/images/product-images/shot-1.png"
      alt="Wrangle markdown editor screenshot"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Content -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <div class="w-full max-w-[740px] flex flex-col gap-6">
      {paragraphs.map((p: string) => (
        <p class="text-secondary text-base leading-[1.8]">{p}</p>
      ))}
    </div>
  </section>

  <!-- Features -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <div class="w-full max-w-[740px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// what you get</h2>
      <div class="h-2"></div>
      {useCase.features.map((feature: string) => (
        <div class="flex items-center gap-3">
          <span class="text-teal-dark text-base">→</span>
          <span class="text-base font-semibold">{feature}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- Second Screenshot -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <img
      src="/images/product-images/shot-5.png"
      alt="Wrangle editor with markdown rendering and XML highlighting"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Guarantee -->
  <section class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-4">
    <h2 class="text-xl lg:text-2xl font-bold text-center">30-day money-back guarantee</h2>
    <p class="text-secondary text-base text-center max-w-[600px]">
      not for you? no worries. get a full refund within 30 days, no questions asked.
    </p>
    <a href="/refund" class="text-teal-dark text-sm hover:underline transition-colors">
      read the refund policy →
    </a>
  </section>

  <!-- Final CTA -->
  <section class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-6">
    <h2 class="text-[32px] lg:text-[40px] font-bold">wrangle</h2>
    <p class="text-secondary text-base text-center max-w-[600px]">
      the markdown editor built for AI-native development. one-time purchase, no subscription.
    </p>
    <div class="flex flex-col items-center gap-3">
      <a
        href="/buy"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-semibold text-dark hover:brightness-110 transition-all"
      >
        buy — $24
      </a>
      <a
        href={downloadUrl}
        class="text-secondary text-sm hover:text-primary transition-colors"
      >
        try free
      </a>
    </div>
    <span class="text-tertiary text-[13px]">macOS 15+ · apple silicon · one-time purchase</span>
  </section>

  <!-- Footer -->
  <footer class="flex items-center justify-between px-5 lg:px-[200px] py-5 border-t border-border-subtle">
    <div class="flex gap-3 text-tertiary text-xs">
      <span>© 2026 wrangle</span>
      <span>·</span>
      <a href="https://jkrush.dev" target="_blank" class="hover:text-secondary transition-colors">built by J-Krush</a>
    </div>
    <div class="flex gap-3 text-tertiary text-xs">
      <a href="mailto:support@wrangleapp.dev" class="hover:text-secondary transition-colors">support</a>
      <span>·</span>
      <a href="https://github.com/J-Krush/wrangle-feedback" class="hover:text-secondary transition-colors">github</a>
      <span>·</span>
      <a href="/terms" class="hover:text-secondary transition-colors">terms</a>
      <span>·</span>
      <a href="/refund" class="hover:text-secondary transition-colors">refund</a>
    </div>
  </footer>
</Layout>
