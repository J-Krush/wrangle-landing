---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";

const version = import.meta.env.APP_VERSION;
const downloadUrl = `https://dl.wrangleapp.dev/Wrangle-${version}.dmg`;
---

<Layout title="wrangle — markdown editor for Claude Code & AI agents (macOS)" canonical="https://wrangleapp.dev/">
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Wrangle",
    "description": "A native macOS markdown editor and terminal workspace for developers working with AI agents like Claude Code and Gemini.",
    "url": "https://wrangleapp.dev",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "macOS 15+",
    "processorRequirements": "Apple Silicon",
    "offers": {
      "@type": "Offer",
      "price": "24",
      "priceCurrency": "USD",
      "availability": "https://schema.org/InStock"
    },
    "author": {
      "@type": "Person",
      "name": "J-Krush",
      "url": "https://jkrush.dev"
    },
    "screenshot": "https://wrangleapp.dev/images/product-images/shot-1.png"
  })} />
  <!-- Header -->
  <header class="flex items-center justify-between px-5 lg:px-[200px] py-4">
    <div class="flex items-center gap-2.5">
      <img
        src="/images/wrangle-logo-13.png"
        alt="wrangle logo"
        class="w-8 h-8 rounded"
      />
      <span class="text-base font-bold">wrangle</span>
    </div>
    <a
      href={downloadUrl}
      class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-6 py-2.5 text-sm font-medium text-dark hover:brightness-110 transition-all"
    >
      try free
    </a>
  </header>

  <!-- Hero -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-12 lg:pb-[80px] gap-8">
    <h1 class="text-[28px] sm:text-[36px] lg:text-[52px] font-bold text-center leading-[1.15] max-w-[1040px]">
      the markdown editor built for AI-native development.
    </h1>
    <p class="text-secondary text-base lg:text-lg text-center leading-relaxed max-w-[800px]">
      a native macOS workspace for developers who live in Claude Code, Gemini, and multi-agent workflows. edit your CLAUDE.md files, run agent sessions with embedded terminals, and get notified the moment an agent needs input or finishes — so you're never guessing which tab to check.
    </p>
    <div class="flex flex-col items-center gap-3">
      <a
        href="/buy"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-semibold text-dark hover:brightness-110 transition-all"
      >
        buy — $24
      </a>
      <a
        href={downloadUrl}
        class="text-secondary text-sm hover:text-primary transition-colors"
      >
        try free — 3 day trial
      </a>
    </div>
    <div class="w-full max-w-[1040px] p-4 rounded-xl bg-black shadow-2xl shadow-black/50">
      <video
        id="sizzle-video"
        src="/videos/Wrangle-sizzle-v1.mov"
        class="w-full h-auto rounded-lg cursor-pointer"
        loop
        muted
        autoplay
        playsinline
      ></video>
    </div>
  </section>

  <!-- Logo + Tagline -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-28 lg:pb-[148px]">
    <img src="/images/wrangle-logo-transparent.png" alt="Wrangle logo" class="w-112 max-w-full h-auto" />
    <h2 class="text-[32px] lg:text-[40px] font-bold text-center -mt-12">wrangle your agents.</h2>
  </section>

  <!-- Features -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// what you get</h2>
      <div class="h-2"></div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">embedded terminals</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">run claude, gemini, and other agents in tabbed terminals. notifications pull you back when they need input or finish.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">session context</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">see the linked claude file, active skills, and MCP servers for every running session at a glance.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">token counting</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">always visible in the status bar. know your context usage before you hit send.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">xml-in-markdown</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">highlights and collapses &lt;tools&gt;, &lt;instructions&gt;, &lt;system&gt; blocks</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">file awareness</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">distinct treatment for CLAUDE.md, SKILL.md, AGENTS.md</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-semibold">native macOS</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">swift, swiftui, apple silicon. not electron.</span>
      </div>
    </div>
  </section>

  <!-- Notifications -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// never miss an agent</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        native macOS notifications tell you exactly when an agent needs input, finishes a task, or requires permission — so you can context-switch away without worry.
      </p>
    </div>
    <div class="w-full max-w-[1040px] flex flex-col gap-4">
      <img src="/images/product-images/notification-1.png" alt="Notification: Claude needs permission to use Bash" class="w-full sm:max-w-[600px] h-auto rounded-lg" loading="lazy" />
      <img src="/images/product-images/notification-2.png" alt="Notification: Ready for input" class="w-full sm:max-w-[600px] h-auto rounded-lg sm:ml-[120px]" loading="lazy" />
      <img src="/images/product-images/notification-3.png" alt="Notification: Claude Code needs your attention" class="w-full sm:max-w-[600px] h-auto rounded-lg sm:ml-[240px]" loading="lazy" />
    </div>
  </section>

  <!-- Editor Preview -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// the editor</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        a markdown editor that understands AI prompts. xml blocks get proper syntax highlighting, collapsible sections, and distinct treatment for CLAUDE.md, SKILL.md, and AGENTS.md files.
      </p>
    </div>
    <img
      src="/images/product-images/shot-1.png"
      alt="Wrangle markdown editor showing a rendered CLAUDE.md file with inline formatting and XML syntax highlighting"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Terminals & Sessions -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <div class="w-full max-w-[1040px] flex flex-col lg:flex-row gap-8 lg:gap-12">
      <!-- Left column: Terminal screenshot -->
      
      <img
        src="/images/product-images/shot-4.png"
        alt="Wrangle terminal with notification toast showing agent ready for input"
        class="w-full lg:w-[55%] h-auto object-contain rounded shadow-2xl shadow-black/50"
        loading="lazy"
      />

      <!-- Right column: Feature descriptions -->
      <div class="w-full lg:w-[45%] flex flex-col gap-6 justify-center">
        <h2 class="text-2xl font-bold">// terminals & sessions</h2>
        <div class="flex flex-col gap-5">
          <div class="flex flex-col gap-1">
            <span class="text-base"><span class="text-teal-dark">→</span> <span class="font-semibold">tabbed terminals</span></span>
            <span class="text-secondary text-sm">multiple agent sessions running side by side. no more hunting for the right terminal window.</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-base"><span class="text-teal-dark">→</span> <span class="font-semibold">smart notifications</span></span>
            <span class="text-secondary text-sm">get pulled back to the right tab when an agent needs a response or finishes its task.</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-base"><span class="text-teal-dark">→</span> <span class="font-semibold">session context</span></span>
            <span class="text-secondary text-sm">every terminal shows its linked claude file, active skills, and connected MCP servers.</span>
          </div>
          <div class="flex flex-col gap-1">
            <span class="text-base"><span class="text-teal-dark">→</span> <span class="font-semibold">multi-project</span></span>
            <span class="text-secondary text-sm">switch between projects without losing running sessions or terminal state.</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Anti-Pitch -->
  <section class="flex items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <p class="text-secondary text-base lg:text-lg text-center leading-[1.7] max-w-[700px]">
      if you're not running AI agents from your editor yet, you will be soon.
      wrangle was built by a developer who manages multiple claude and gemini
      sessions every day and got tired of context-switching between terminals,
      editors, and notification windows. one app. everything in view.
    </p>
  </section>

  <!-- Guarantee -->
  <section class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-4">
    <h2 class="text-xl lg:text-2xl font-bold text-center">30-day money-back guarantee</h2>
    <p class="text-secondary text-base text-center max-w-[600px]">
      not for you? no worries. get a full refund within 30 days, no questions asked.
    </p>
    <a href="/refund" class="text-teal-dark text-sm hover:underline transition-colors">
      read the refund policy →
    </a>
  </section>

  <!-- Final CTA -->
  <section id="download" class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-6">
    <h2 class="text-[32px] lg:text-[40px] font-bold">wrangle</h2>
    <div class="flex flex-col items-center gap-3">
      <a
        href="/buy"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-semibold text-dark hover:brightness-110 transition-all"
      >
        buy — $24
      </a>
      <a
        href={downloadUrl}
        class="text-secondary text-sm hover:text-primary transition-colors"
      >
        try free — 3 day trial
      </a>
    </div>
    <span class="text-tertiary text-[13px]">macOS 15+ · apple silicon · one-time purchase</span>
  </section>

  <!-- Footer -->
  <footer class="flex items-center justify-between px-5 lg:px-[200px] py-5 border-t border-border-subtle">
    <div class="flex gap-3 text-tertiary text-xs">
      <span>© 2026 wrangle</span>
      <span>·</span>
      <a href="https://jkrush.dev" target="_blank" class="hover:text-secondary transition-colors">built by J-Krush</a>
    </div>
    <div class="flex gap-3 text-tertiary text-xs">
      <a href="mailto:support@wrangleapp.dev" class="hover:text-secondary transition-colors">support</a>
      <span>·</span>
      <a href="https://github.com/J-Krush/wrangle-feedback" class="hover:text-secondary transition-colors">github</a>
      <span>·</span>
      <a href="/terms" class="hover:text-secondary transition-colors">terms</a>
      <span>·</span>
      <a href="/refund" class="hover:text-secondary transition-colors">refund</a>
    </div>
  </footer>

  <script>
    const video = document.getElementById('sizzle-video') as HTMLVideoElement;
    video.addEventListener('click', () => {
      if (video.paused) {
        video.play();
      } else {
        video.pause();
      }
    });
  </script>
</Layout>
