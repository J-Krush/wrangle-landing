---
import Layout from "../layouts/Layout.astro";
import "../styles/global.css";
---

<Layout title="wrangle — free macOS markdown editor for AI developers" canonical="https://wrangleapp.dev/">
  <!-- JSON-LD Structured Data -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "Wrangle",
    "description": "A native macOS markdown editor, terminal, and browser workspace for developers working with AI agents like Claude Code and Gemini.",
    "url": "https://wrangleapp.dev",
    "applicationCategory": "DeveloperApplication",
    "operatingSystem": "macOS 15+",
    "processorRequirements": "Apple Silicon",
    "author": {
      "@type": "Person",
      "name": "J-Krush",
      "url": "https://jkrush.dev"
    },
    "creator": {
      "@type": "Person",
      "name": "J Krush",
      "url": "https://jkrush.dev"
    },
    "screenshot": "https://wrangleapp.dev/images/product-images/editor-simple.png"
  })} />
  <!-- Header -->
  <header class="flex items-center justify-between px-5 lg:px-[200px] py-4">
    <div class="flex items-center gap-2.5">
      <img
        src="/images/wrangle-logo-13.png"
        alt="wrangle logo"
        class="w-8 h-8 rounded"
      />
      <span class="text-base font-bold">wrangle</span>
    </div>
    <div class="flex flex-row items-center gap-2">
      <a
        href="https://github.com/J-Krush/wrangle/releases/latest"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-4 py-2 text-sm font-bold text-dark hover:brightness-110 transition-all"
      >
        Download for macOS
      </a>
      <a
        href="https://github.com/J-Krush/wrangle"
        class="inline-flex items-center justify-center gap-1.5 rounded-lg border border-border px-4 py-2 text-sm font-bold text-primary hover:border-teal-dark hover:text-teal transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>
  </header>

  <!-- Hero -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-12 lg:pb-[80px] gap-8">
    <h1 class="text-[28px] sm:text-[36px] lg:text-[52px] font-bold text-center leading-[1.15] max-w-[1040px]">
      native macOS markdown editor for AI agents — free and open source.
    </h1>
    <p class="text-secondary text-base lg:text-lg text-center leading-relaxed max-w-[800px]">
      built for developers driving Claude Code, Gemini, and multi-agent workflows. edit CLAUDE.md files, run agent sessions in embedded terminals, and stay in flow without context-switching across windows.
    </p>
    <div class="flex flex-col sm:flex-row items-center gap-3">
      <a
        href="https://github.com/J-Krush/wrangle/releases/latest"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-bold text-dark hover:brightness-110 transition-all"
      >
        Download for macOS
      </a>
      <a
        href="https://github.com/J-Krush/wrangle"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-8 py-4 text-base font-bold text-primary hover:border-teal-dark hover:text-teal transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>
    <span class="text-tertiary text-sm">macOS 15+ · apple silicon · free + open source</span>
    <div class="w-full max-w-[1040px] p-4 rounded-xl bg-black shadow-2xl shadow-black/50">
      <video
        id="sizzle-video"
        src="/videos/wrangle-1.2-sizzle.mp4"
        class="w-full h-auto rounded-lg cursor-pointer"
        loop
        muted
        autoplay
        playsinline
      ></video>
    </div>
  </section>

  <!-- Logo + Tagline -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] pt-16 lg:pt-[100px] pb-28 lg:pb-[148px]">
    <img src="/images/wrangle-logo-transparent.png" alt="Wrangle logo" class="w-112 max-w-full h-auto" />
    <h2 class="text-[32px] lg:text-[40px] font-bold text-center -mt-12">wrangle your agents.</h2>
  </section>

  <!-- Features -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// what you get</h2>
      <div class="h-2"></div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">embedded terminals</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">run claude, gemini, and other agents in tabbed terminals. notifications pull you back when they need input or finish.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">embedded browser</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">webkit tabs next to your editor, with console, network, elements, and cookies panels built in. inspect the thing your agent just built without leaving the window.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">projects</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">group locations, terminals, and browsers under named projects. dashboard, todos, and a canvas view per project.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">session context</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">see the linked claude file, active skills, and MCP servers for every running session at a glance.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">token counting</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">always visible in the status bar. know your context usage before you hit send.</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">xml-in-markdown</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">highlights and collapses &lt;tools&gt;, &lt;instructions&gt;, &lt;system&gt; blocks</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">file awareness</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">distinct treatment for CLAUDE.md, SKILL.md, AGENTS.md</span>
      </div>
      <div class="flex flex-col sm:flex-row items-start sm:items-center gap-2">
        <span class="text-teal-dark text-base">→</span>
        <span class="text-base font-bold">native macOS</span>
        <span class="text-tertiary text-base hidden sm:inline">—</span>
        <span class="text-secondary text-base">swift, swiftui, apple silicon. not electron.</span>
      </div>
    </div>
  </section>

  <!-- Notifications -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// never miss an agent</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        native macOS notifications tell you exactly when an agent needs input, finishes a task, or requires permission — so you can context-switch away without worry.
      </p>
    </div>
    <div class="w-full max-w-[1040px] flex flex-col gap-4">
      <img src="/images/product-images/notification-1.png" alt="Notification: Claude needs permission to use Bash" class="w-full sm:max-w-[600px] h-auto rounded-lg" loading="lazy" />
      <img src="/images/product-images/notification-2.png" alt="Notification: Ready for input" class="w-full sm:max-w-[600px] h-auto rounded-lg sm:ml-[120px]" loading="lazy" />
      <img src="/images/product-images/notification-3.png" alt="Notification: Claude Code needs your attention" class="w-full sm:max-w-[600px] h-auto rounded-lg sm:ml-[240px]" loading="lazy" />
    </div>
  </section>

  <!-- Editor Preview -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// the editor</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        a markdown editor that understands AI prompts. xml blocks get proper syntax highlighting, collapsible sections, and distinct treatment for CLAUDE.md, SKILL.md, and AGENTS.md files.
      </p>
    </div>
    <img
      src="/images/product-images/editor-simple.png"
      alt="Wrangle markdown editor showing a CLAUDE.md file with inline formatting and XML syntax highlighting"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Browser Preview -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// the browser</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        an embedded webkit browser sits right next to your editor and terminals. tabs, back/forward, url bar, and full devtools — console, network, elements, cookies. your agent just shipped a change? inspect it without leaving wrangle.
      </p>
    </div>
    <div class="w-full max-w-[1040px] p-4 rounded-xl bg-black shadow-2xl shadow-black/50">
      <video
        id="browser-video"
        src="/videos/browser-feature.mp4"
        class="w-full h-auto rounded-lg cursor-pointer"
        loop
        muted
        autoplay
        playsinline
        preload="metadata"
      ></video>
    </div>
  </section>

  <!-- Terminals & Sessions -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// terminals & sessions</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        run multiple agent sessions in tabbed terminals — claude, gemini, codex, whatever. each terminal shows its linked claude file, active skills, and connected MCP servers, with notifications that pull you back the moment an agent needs input or finishes a task.
      </p>
    </div>
    <img
      src="/images/product-images/terminal.png"
      alt="Wrangle terminal with notification toast showing agent ready for input"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Full Workspace Overview -->
  <section class="flex flex-col items-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-8">
    <div class="w-full max-w-[1040px] flex flex-col gap-6">
      <h2 class="text-2xl font-bold">// everything in one view</h2>
      <p class="text-secondary text-base leading-relaxed max-w-[700px]">
        editor, terminal, browser, project dashboard, todos, and agent sessions — all in a single window, organized by project. context-switching happens inside the app, not between apps.
      </p>
    </div>
    <img
      src="/images/product-images/project-overview.png"
      alt="Wrangle full workspace view showing the editor, terminal, embedded browser, project dashboard, and sidebar project rail all visible at once"
      class="w-full max-w-[1040px] h-auto rounded shadow-2xl shadow-black/50"
      loading="lazy"
    />
  </section>

  <!-- Anti-Pitch -->
  <section class="flex items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <p class="text-secondary text-base lg:text-lg text-center leading-[1.7] max-w-[700px]">
      if you're not running AI agents from your editor yet, you will be soon.
      wrangle was built by a developer who manages multiple claude and gemini
      sessions every day — a native macOS workspace for that work, shaped
      around it instead of bolted onto a text editor. one app. everything in view.
    </p>
  </section>

  <!-- AI Disclosure -->
  <section class="flex items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px]">
    <p class="text-tertiary text-sm text-center leading-relaxed max-w-[600px]">
      built with heavy AI assistance and reviewed by a professional Swift developer before shipping. a tool for AI-native dev, built the same way.
    </p>
  </section>

  <!-- Final CTA -->
  <section id="download" class="flex flex-col items-center justify-center px-5 lg:px-[200px] py-16 lg:py-[100px] gap-6">
    <h2 class="text-[32px] lg:text-[40px] font-bold">wrangle</h2>
    <div class="flex flex-col sm:flex-row items-center gap-3">
      <a
        href="https://github.com/J-Krush/wrangle/releases/latest"
        class="inline-flex items-center justify-center rounded-lg bg-linear-to-b from-teal to-teal-dark px-8 py-4 text-base font-bold text-dark hover:brightness-110 transition-all"
      >
        Download for macOS
      </a>
      <a
        href="https://github.com/J-Krush/wrangle"
        class="inline-flex items-center justify-center gap-2 rounded-lg border border-border px-8 py-4 text-base font-bold text-primary hover:border-teal-dark hover:text-teal transition-all"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 16 16" fill="currentColor" aria-hidden="true"><path d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2 .37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.013 8.013 0 0 0 16 8c0-4.42-3.58-8-8-8z"/></svg>
        Star on GitHub
      </a>
    </div>
    <span class="text-tertiary text-sm">macOS 15+ · apple silicon · free + open source</span>
  </section>

  <!-- Footer -->
  <footer class="flex items-center justify-between px-5 lg:px-[200px] py-5 border-t border-border-subtle">
    <div class="flex gap-3 text-tertiary text-sm">
      <span>© 2026 wrangle</span>
      <span>·</span>
      <a href="https://jkrush.dev" target="_blank" class="hover:text-secondary transition-colors">Built by J Krush</a>
      <span>·</span>
      <a href="./LICENSE" class="hover:text-secondary transition-colors">MIT</a>
    </div>
    <div class="flex gap-3 text-tertiary text-sm">
      <a href="mailto:support@wrangleapp.dev" class="hover:text-secondary transition-colors">support</a>
      <span>·</span>
      <a href="https://github.com/J-Krush/wrangle" class="hover:text-secondary transition-colors">github</a>
    </div>
  </footer>

  <script>
    const videos = ['sizzle-video', 'browser-video']
      .map((id) => document.getElementById(id) as HTMLVideoElement | null)
      .filter((v): v is HTMLVideoElement => v !== null);

    videos.forEach((video) => {
      video.addEventListener('click', () => {
        if (video.paused) {
          video.play();
        } else {
          video.pause();
        }
      });
    });
  </script>
</Layout>
